{
  "buildCommand": "composer install",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "now-php@8.2"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php?$1"
    }
  ],
  "env": {
    "APP_NAME": "Reny Birthday Website",
    "APP_ENV": "production"
  }
}
